{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Firmware For Wokwi",
      "type": "shell",
      "command": "./build_wokwi.sh",
      "options": {
        "cwd": "${workspaceFolder}/arduino-wokwi-blink"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Start Wokwi Simulator",
      "type": "shell",
      "command": "echo \"${command:wokwi-vscode.start}\"",
      "problemMatcher": []
    },
    {
      "label": "Build And Start Wokwi",
      "dependsOrder": "sequence",
      "dependsOn": ["Build Firmware For Wokwi", "Start Wokwi Simulator"],
      "problemMatcher": []
    }
  ]
}
